# Copy to .env and fill in. Paper mode (phase 1-2) needs none of these; they are
# required only when a broker's live phase is enabled. Names match each SDK's docs.

# --- Zerodha (Kite Connect) ---
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=          # regenerate daily via login flow

# --- Upstox (upstox-python-sdk, OAuth2) ---
UPSTOX_API_KEY=             # app/client id
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=
UPSTOX_ACCESS_TOKEN=        # regenerate daily via OAuth redirect

# --- Angel One (SmartApi-python) ---
ANGELONE_API_KEY=
ANGELONE_CLIENT_CODE=
ANGELONE_MPIN=
ANGELONE_TOTP_SECRET=       # 2FA base32 secret; TOTP generated per login

# --- Alpaca (alpaca-py, US equities) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true           # true -> Alpaca paper endpoint
